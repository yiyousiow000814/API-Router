{
  "name": "api-router",
  "private": true,
  "version": "0.4.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "check:gateway-provider-id": "node tools/checks/check-gateway-provider-id.mjs",
    "check:line-endings": "node tools/checks/check-line-endings.mjs",
    "check:web-codex-assets": "node tools/checks/check-web-codex-assets.mjs",
    "check:codex-gateway": "node tools/checks/check-codex-gateway.mjs",
    "debug:dump": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File tools/diagnostics/debug-dump.ps1",
    "dev": "npm run check:gateway-provider-id && vite",
    "build": "npm run check:gateway-provider-id && npm run check:line-endings && npm run check:web-codex-assets && tsc && vite build",
    "preview": "vite preview",
    "tauri": "node tools/windows/run-with-win-sdk.mjs node node_modules/@tauri-apps/cli/tauri.js",
    "build:root-exe": "node tools/build/build-root-exe.mjs",
    "build:root-installers": "npm run tauri -- build",
    "ui:tauri": "node tests/ui/tauri-ui-check.mjs",
    "ui:check": "node tests/ui/run-tauri-if-windows.mjs",
    "ui:e2e:codex-threadlist-scroll": "node tests/ui/e2e/codex-web/threadlist-scroll.mjs",
    "ui:e2e:codex-threadlist-enter": "node tests/ui/e2e/codex-web/threadlist-enter.mjs",
    "ui:e2e:codex-threadlist-enter-race": "node tests/ui/e2e/codex-web/threadlist-enter-race.mjs",
    "ui:e2e:codex-threadlist-desktop-refresh-no-reenter": "node tests/ui/e2e/codex-web/threadlist-desktop-refresh-no-reenter.mjs",
    "ui:e2e:codex-threadlist-open-guard": "node tests/ui/e2e/codex-web/threadlist-open-guard.mjs",
    "ui:e2e:codex-open-thread-history-only": "node tests/ui/e2e/codex-web/open-thread-history-only.mjs",
    "ui:e2e:codex-history-render": "node tests/ui/e2e/codex-web/history-render.mjs",
    "ui:e2e:codex-live-thread-sync": "node tests/ui/e2e/codex-web/live-thread-sync.mjs",
    "ui:e2e:codex-commentary-archive": "node tests/ui/e2e/codex-web/commentary-archive.mjs",
    "ui:e2e:codex-plan-interrupt-cleanup": "node tests/ui/e2e/codex-web/plan-interrupt-cleanup.mjs",
    "ui:e2e:codex-runtime-panels-no-reenter": "node tests/ui/e2e/codex-web/runtime-panels-no-reenter.mjs",
    "ui:e2e:codex-send-turn-live": "node tests/ui/e2e/codex-web/send-turn-live.mjs",
    "ui:e2e:codex-reconnect-error-sequence": "node tests/ui/e2e/codex-web/reconnect-error-sequence.mjs",
    "check:codex-open-latency": "node tools/benchmarks/thread-open-latency.mjs --threads 1 --samples 3 --max-visible-ms 3000",
    "e2e:build-root-exe-restart": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File tests/e2e/build/build-root-exe-restart.ps1",
    "backend:check": "npm run check:rust",
    "check:rust": "node tools/checks/run-rust-gate.mjs clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings && node tools/checks/run-rust-gate.mjs test --manifest-path src-tauri/Cargo.toml --locked --no-run",
    "check:ci-local": "npm run build && node tools/windows/run-with-win-sdk.mjs cargo fmt --manifest-path src-tauri/Cargo.toml --check && npm run check:rust",
    "check:all": "npm run test && npm run check:line-endings && npm run backend:check && npm run ui:check",
    "build:root-exe:checked": "node tools/build/build-root-exe-checked.mjs",
    "build:root-exe:guarded": "npm run check:codex-gateway && npm run build:root-exe:checked",
    "ui:e2e:requests-reload": "node tests/ui/e2e/tauri/requests-reload.mjs",
    "ui:e2e:requests-graph-hydration": "node tests/ui/e2e/tauri/requests-graph-hydration.mjs",
    "test": "npm run check:gateway-provider-id && vitest run",
    "bench:thread-open": "node tools/benchmarks/thread-open-latency.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "pngjs": "^7.0.0",
    "selenium-webdriver": "^4.40.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
