{
  "name": "api-router",
  "private": true,
  "version": "0.4.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "check:gateway-provider-id": "node scripts/check-gateway-provider-id.mjs",
    "check:line-endings": "node scripts/check-line-endings.mjs",
    "check:web-codex-assets": "node scripts/check-web-codex-assets.mjs",
    "check:codex-gateway": "node scripts/check-codex-gateway.mjs",
    "dev": "npm run check:gateway-provider-id && vite",
    "build": "npm run check:gateway-provider-id && npm run check:line-endings && npm run check:web-codex-assets && tsc && vite build",
    "preview": "vite preview",
    "tauri": "node scripts/run-with-win-sdk.mjs tauri",
    "build:root-exe": "npm run build && node scripts/run-with-win-sdk.mjs cargo build --manifest-path src-tauri/Cargo.toml --release && node scripts/copy-root-exe.mjs && node scripts/open-root-exe.mjs",
    "build:root-installers": "node scripts/run-with-win-sdk.mjs tauri build",
    "ui:tauri": "node scripts/tauri-ui-check.mjs",
    "ui:check": "node scripts/run-ui-tauri-if-windows.mjs",
    "ui:e2e:codex-threadlist-scroll": "node scripts/codex-web-e2e-threadlist-scroll.mjs",
    "ui:e2e:codex-threadlist-enter": "node scripts/codex-web-e2e-threadlist-enter.mjs",
    "ui:e2e:codex-threadlist-enter-race": "node scripts/codex-web-e2e-threadlist-enter-race.mjs",
    "ui:e2e:codex-threadlist-desktop-refresh-no-reenter": "node scripts/codex-web-e2e-threadlist-desktop-refresh-no-reenter.mjs",
    "ui:e2e:codex-threadlist-open-guard": "node scripts/codex-web-e2e-threadlist-open-guard.mjs",
    "ui:e2e:codex-open-thread-history-only": "node scripts/codex-web-e2e-open-thread-history-only.mjs",
    "ui:e2e:codex-history-render": "node scripts/codex-web-e2e-history-render.mjs",
    "ui:e2e:codex-live-thread-sync": "node scripts/codex-web-e2e-live-thread-sync.mjs",
    "ui:e2e:codex-commentary-archive": "node scripts/codex-web-e2e-commentary-archive.mjs",
    "ui:e2e:codex-plan-interrupt-cleanup": "node scripts/codex-web-e2e-plan-interrupt-cleanup.mjs",
    "ui:e2e:codex-runtime-panels-no-reenter": "node scripts/codex-web-e2e-runtime-panels-no-reenter.mjs",
    "ui:e2e:codex-send-turn-live": "node scripts/codex-web-e2e-send-turn-live.mjs",
    "check:codex-open-latency": "node scripts/benchmark-thread-open-latency.mjs --threads 1 --samples 3 --max-visible-ms 3000",
    "e2e:build-root-exe-restart": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/build-root-exe.e2e.ps1",
    "backend:check": "node scripts/run-with-win-sdk.mjs cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "check:ci-local": "npm run build && node scripts/run-with-win-sdk.mjs cargo fmt --manifest-path src-tauri/Cargo.toml --check && node scripts/run-with-win-sdk.mjs cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings && node scripts/run-with-win-sdk.mjs cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "check:all": "npm run test && npm run check:line-endings && npm run backend:check && npm run ui:check",
    "build:root-exe:checked": "node scripts/run-ui-tauri-if-windows.mjs && npm run build:root-exe",
    "build:root-exe:guarded": "npm run check:codex-gateway && npm run build:root-exe:checked",
    "ui:e2e:requests-reload": "node scripts/tauri-e2e-requests-reload.mjs",
    "ui:e2e:requests-graph-hydration": "node scripts/tauri-e2e-requests-graph-hydration.mjs",
    "test": "npm run check:gateway-provider-id && vitest run",
    "bench:thread-open": "node scripts/benchmark-thread-open-latency.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "pngjs": "^7.0.0",
    "selenium-webdriver": "^4.40.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
